<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Regus Bloomfield Hills - Suite 350 Booking</title>
    <style>
        :root {
            --regus-red: #cc0000;
            --available-bg: #e8f5e9;
            --available-text: #2e7d32;
            --occupied-bg: #ffebee;
            --occupied-text: #c62828;
            --reserved-bg: #fff3e0;
            --reserved-text: #ef6c00;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            min-height: 100vh;
            padding: 40px 20px;
        }

        .container {
            display: flex;
            flex-direction: row;
            gap: 40px;
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            max-width: 1000px;
            width: 100%;
        }

        /* MAP SECTION STYLING */
        .map-section {
            flex: 1;
            border: 3px solid var(--regus-red);
            padding: 20px;
            border-radius: 8px;
            max-width: 300px;
        }

        .map-header {
            text-align: center;
            margin-bottom: 20px;
        }

        .map-header h2 {
            margin: 0;
            color: var(--regus-red);
            font-size: 1.2rem;
            text-transform: uppercase;
        }

        .legend {
            display: flex;
            justify-content: space-around;
            font-size: 11px;
            margin-bottom: 15px;
            border-bottom: 1px solid #eee;
            padding-bottom: 10px;
        }

        .legend-item { display: flex; align-items: center; gap: 5px; }
        .dot { width: 10px; height: 10px; border-radius: 50%; }

        .office-grid {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .office-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

        .office-unit {
            border: 1px solid #ddd;
            padding: 15px 5px;
            text-align: center;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.2s;
            border-radius: 4px;
        }

        .office-unit:hover:not(.status-occupied) {
            transform: scale(1.02);
            border-color: var(--regus-red);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

        /* Status Classes */
        .status-available { background-color: var(--available-bg); color: var(--available-text); }
        .status-occupied { background-color: var(--occupied-bg); color: var(--occupied-text); cursor: not-allowed; opacity: 0.7; }
        .status-reserved { background-color: var(--reserved-bg); color: var(--reserved-text); }

        /* BOOKING SIDEBAR STYLING */
        .sidebar {
            flex: 1.5;
            display: flex;
            flex-direction: column;
        }

        .address-info {
            border-bottom: 2px solid #eee;
            padding-bottom: 15px;
            margin-bottom: 20px;
        }

        .address-info h1 { margin: 0; font-size: 1.8rem; }
        .address-info p { margin: 5px 0; color: #666; }

        .booking-card {
            background: #fafafa;
            border: 1px solid #eee;
            padding: 25px;
            border-radius: 8px;
        }

        .hidden { display: none; }

        label { display: block; margin-bottom: 8px; font-weight: bold; font-size: 0.9rem; }
        input, select {
            width: 100%;
            padding: 12px;
            margin-bottom: 20px;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
        }

        .btn-reserve {
            background-color: #333;
            color: white;
            border: none;
            padding: 15px;
            width: 100%;
            border-radius: 4px;
            font-weight: bold;
            cursor: pointer;
            font-size: 1rem;
        }

        .btn-reserve:hover { background-color: #000; }

        .search-bar {
            margin-bottom: 20px;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 20px;
            width: 100%;
            box-sizing: border-box;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="map-section">
        <div class="map-header">
            <h2>Red Zone Inventory</h2>
            <p style="font-size: 12px;">Suite 350</p>
        </div>

        <div class="legend">
            <div class="legend-item"><div class="dot" style="background:var(--available-text)"></div> Avail</div>
            <div class="legend-item"><div class="dot" style="background:var(--reserved-text)"></div> AA 6-8</div>
            <div class="legend-item"><div class="dot" style="background:var(--occupied-text)"></div> Full</div>
        </div>

        <div class="office-grid">
            <div class="office-row">
                <div class="office-unit status-available" onclick="selectOffice('375', 'External')">375</div>
                <div class="office-unit status-available" onclick="selectOffice('374', 'Internal')">374</div>
            </div>
            <div class="office-row">
                <div class="office-unit status-available" onclick="selectOffice('372', 'External')">372</div>
                <div class="office-unit status-reserved" onclick="selectOffice('373', 'Internal')">373</div>
            </div>
            <div class="office-row">
                <div class="office-unit status-available" onclick="selectOffice('371', 'External')">371 🖨️</div>
                <div class="office-unit status-available" onclick="selectOffice('370', 'Internal')">370</div>
            </div>
            <div class="office-row">
                <div class="office-unit status-occupied">368 (Conf)</div>
                <div class="office-unit status-available" onclick="selectOffice('364', 'External')">364</div>
            </div>
            <div class="office-row">
                <div class="office-unit status-available" onclick="selectOffice('362', 'External')">362</div>
                <div class="office-unit status-available" onclick="selectOffice('352', 'Internal')">352</div>
            </div>
            <div class="office-row">
                <div class="office-unit status-available" onclick="selectOffice('359', 'External')">359</div>
                <div class="office-unit status-available" onclick="selectOffice('350', 'External')">350</div>
            </div>
            <div class="office-unit status-available" style="margin-top:5px;" onclick="selectOffice('346', 'Executive Suite')">346 (Large)</div>
        </div>
    </div>

    <div class="sidebar">
        <div class="address-info">
            <h1>Bloomfield Hills</h1>
            <p>41000 Woodward Avenue, Bloomfield, MI 48304</p>
        </div>

        <input type="text" class="search-bar" placeholder="Search office # (e.g. 346)...">

        <div id="welcome-msg">
            <p style="color: #888; text-align: center; margin-top: 50px;">
                Please select a highlighted office from the map to view details and check availability.
            </p>
        </div>

        <div id="booking-ui" class="hidden">
            <div class="booking-card">
                <h3 style="margin-top:0;">Office <span id="display-id" style="color:var(--regus-red)"></span></h3>
                <p id="display-type" style="font-size:0.9rem; color:#666; margin-bottom:20px;"></p>
                
                <label>Select Duration</label>
                <select>
                    <option>Day Office (8:30am - 5:00pm)</option>
                    <option>Full Week</option>
                    <option>Monthly Membership</option>
                </select>

                <label>Start Date</label>
                <input type="date">

                <button class="btn-reserve" onclick="completeBooking()">Reserve Now</button>
            </div>
        </div>
    </div>
</div>

<script>
    function selectOffice(id, type) {
        // Show Booking UI
        document.getElementById('welcome-msg').classList.add('hidden');
        document.getElementById('booking-ui').classList.remove('hidden');
        
        // Update Details
        document.getElementById('display-id').innerText = id;
        document.getElementById('display-type').innerText = type + " Unit - Suite 350 Section";
    }

    function completeBooking() {
        const id = document.getElementById('display-id').innerText;
        alert("Booking confirmed for Office " + id + " at 41000 Woodward Avenue.");
        window.location.reload();
    }
</script>

</body>
</html>
